# ローカル開発用の設定ファイルのひな形。
#   cp frontend/.env.example frontend/.env.development
# .env.development は git 管理外。
#
# 本番ではこのファイルは使わない。Vercel のダッシュボードで環境変数を設定する。

# Rails API のベース URL。ブラウザから叩くため、コンテナ名（backend）ではなく
# localhost を指す。本番では Render 上の Rails の URL を設定する。
#
# NEXT_PUBLIC_ が付く変数はブラウザの JS バンドルに埋め込まれ、誰でも見られる。
# API キーなどの秘密情報を、この接頭辞を付けて置いてはいけない。
NEXT_PUBLIC_API_BASE_URL=http://localhost:3000
