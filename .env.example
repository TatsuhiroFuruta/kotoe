# ローカル開発用の設定ファイルのひな形。
#   cp .env.example .env.development
# .env.development は git 管理外（秘密情報を書いてもコミットされない）。
#
# 本番ではこのファイルは使わない。Render / Vercel / Neon のダッシュボードで
# 同名の環境変数を設定する。

# --- PostgreSQL（db コンテナ）---
# ローカルの捨て DB の認証情報。本番は Neon が発行する接続文字列を使うため不要。
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=kotoe_development

# --- Rails（backend コンテナ）---
# POSTGRES_* と一致させること（ずれると接続できない）。
# 本番（Render）では Neon の「プール接続文字列」を設定し、接続枯渇を避ける。
DATABASE_URL=postgresql://postgres:password@db:5432/kotoe_development

# ブラウザから Rails API を叩けるオリジン（カンマ区切り）。フロントとバックは別オリジンのため必要。
# ローカルは Next.js の開発サーバー。本番（Render）には Vercel の URL を設定する。
CORS_ALLOWED_ORIGINS=http://localhost:3001

# NOTE: 本番（Render）には TZ=Asia/Tokyo も設定すること。
# 設定しないと日付境界が9時間ずれ、生成回数の日次上限が意図どおりに効かない。
