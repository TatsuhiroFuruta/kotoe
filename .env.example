# ローカル開発用の設定ファイルのひな形。
#   cp .env.example .env.development
# .env.development は git 管理外（秘密情報を書いてもコミットされない）。
#
# 本番ではこのファイルは使わない。Render / Vercel / Neon のダッシュボードで
# 同名の環境変数を設定する。

# --- PostgreSQL（db コンテナ）---
# ローカルの捨て DB の認証情報。本番は Neon が発行する接続文字列を使うため不要。
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=kotoe_development

# --- Rails（backend コンテナ）---
# POSTGRES_* と一致させること（ずれると接続できない）。
# 本番（Render）では Neon の「プール接続文字列」を設定し、接続枯渇を避ける。
DATABASE_URL=postgresql://postgres:password@db:5432/kotoe_development

# ブラウザから Rails API を叩けるオリジン（カンマ区切り）。フロントとバックは別オリジンのため必要。
# ローカルは Next.js の開発サーバー。本番（Render）には Vercel の URL を設定する。
CORS_ALLOWED_ORIGINS=http://localhost:3001

# Vercel のプレビューURLはデプロイごとに変わるため、完全一致リストではなく正規表現で許可する。
# 値は 8-2a（本番スケルトン）でチーム slug が確定してから Render の環境変数に設定する。
# ローカル開発では不要（未設定なら完全一致リストだけで判定する）。
#
# チーム slug まで含めること。"kotoe-" だけで絞ると、第三者が同じ接頭辞で
# Vercel プロジェクトを作るだけで許可されてしまう。
# 前後の \A \z は実装側（lib/cors/allowed_origins.rb）で付けるので書かなくてよい。
# CORS_ALLOWED_ORIGIN_REGEX=https://kotoe-[a-z0-9-]+-<your-team-slug>\.vercel\.app

# JWT の署名鍵。これが漏れると誰でもログイン済みのトークンを偽造できる。
# 値は各自で生成すること: docker compose exec backend bin/rails secret
# 本番（Render）には別の値を設定する（ローカルと共用しない）。
JWT_SECRET_KEY=

# NOTE: 本番（Render）には TZ=Asia/Tokyo も設定すること。
# 設定しないと日付境界が9時間ずれ、生成回数の日次上限が意図どおりに効かない。
