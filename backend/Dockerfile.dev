# 開発用イメージ。本番（Render）用の Dockerfile は別途用意する。
FROM ruby:3.4-slim

# 本番（Render）でも同じ TZ を環境変数で設定すること。
# 設定しないとローカル(JST)と本番(UTC)で日付境界がずれ、生成回数の日次上限が9時間ずれる。
ENV LANG=C.UTF-8 \
    TZ=Asia/Tokyo \
    BUNDLE_PATH=/usr/local/bundle \
    RAILS_ENV=development

# build-essential / pkg-config: ネイティブ拡張のビルド
# libpq-dev: pg gem のビルド / postgresql-client: psql・pg_dump
# libyaml-dev: psych のビルド / tzdata: TZ の解決（slim には含まれない）
RUN apt-get update -qq \
  && apt-get install -y --no-install-recommends \
       build-essential \
       pkg-config \
       libpq-dev \
       libyaml-dev \
       postgresql-client \
       tzdata \
  && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Gemfile だけ先に入れて bundle install をレイヤキャッシュに乗せる
COPY Gemfile Gemfile.lock ./
RUN bundle install

COPY . .

COPY entrypoint.dev.sh /usr/local/bin/entrypoint.dev.sh
RUN chmod +x /usr/local/bin/entrypoint.dev.sh
ENTRYPOINT ["entrypoint.dev.sh"]

EXPOSE 3000
CMD ["bin/rails", "server", "-b", "0.0.0.0", "-p", "3000"]
