# エディタ / OS 由来のファイルはリポジトリルートの .gitignore で除外している。

# bundler の設定
/.bundle

# 環境変数ファイル（秘密情報）
/.env*
!/.env.example

# ログ・一時ファイル
/log/*
/tmp/*
!/log/.keep
!/tmp/.keep

# pid ファイル（ディレクトリは残す）
/tmp/pids/*
!/tmp/pids/.keep

# アップロードされたファイル
/storage/*
!/storage/.keep
/tmp/storage/*
!/tmp/storage/.keep

# credentials の復号鍵。master.key だけでなく、環境別クレデンシャル
# （config/credentials/production.key 等）も除外する。
/config/master.key
/config/credentials/*.key

# RSpec が `--only-failures` のために書き出す実行結果。
/spec/examples.txt

# ホストで `bundle install --path vendor/bundle` を実行した場合の gem の実体。
# 通常は BUNDLE_PATH=/usr/local/bundle（コンテナ内）に入るため生成されない。
/vendor/bundle
/vendor/cache
